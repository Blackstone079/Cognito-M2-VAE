#!/bin/bash
#PBS -N cognito_extract_stream
#PBS -l select=1:ncpus=8:mem=64gb
#PBS -l walltime=08:00:00
#PBS -j oe

cd "$PBS_O_WORKDIR"

module purge
module load miniforge/3

# activate your env (edit if needed)
eval "$(~/miniforge3/bin/conda shell.bash hook)"
conda activate cognito

python pipelines/legacy_single_target/extract.py --config pipelines/legacy_single_target/config.yaml
