#!/bin/bash
#PBS -N cognito_train_m2
#PBS -l select=1:ncpus=16:mem=128gb:ngpus=1
#PBS -l walltime=72:00:00
#PBS -j oe

cd "$PBS_O_WORKDIR"

module purge
module load miniforge/3

eval "$(~/miniforge3/bin/conda shell.bash hook)"
conda activate cognito

python experiments/10_train_m2_memmap.py --config experiments/config_m2.yaml
